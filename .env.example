# =====================================================
# AI SUMMARIZATION SYSTEM - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control!

# =====================================================
# OpenAI API Configuration
# =====================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=###

# Model Selection
# Options: gpt-3.5-turbo (faster, cheaper) or gpt-4 (more accurate, expensive)
LLM_MODEL=gpt-3.5-turbo

# =====================================================
# Database Configuration
# =====================================================
# SQLite database path (structured data)
SQLITE_DB_PATH=data/databases/structured.db

# ChromaDB path (vector embeddings)
CHROMADB_PATH=data/databases/chromadb

# =====================================================
# Application Settings
# =====================================================
# Maximum file upload size in megabytes
MAX_FILE_SIZE_MB=200

# Text chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Number of search results to retrieve
TOP_K_RESULTS=5

# =====================================================
# Processing Settings
# =====================================================
# Enable/disable features
ENABLE_OCR=true
ENABLE_VIDEO_PROCESSING=true
ENABLE_AUDIO_TRANSCRIPTION=true

# =====================================================
# Logging Configuration
# =====================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

# =====================================================
# Optional: MongoDB Configuration (if using)
# =====================================================
# MONGODB_URI=mongodb://localhost:27017/
# MONGODB_DB_NAME=ai_summarization
# MONGODB_USERNAME=admin
# MONGODB_PASSWORD=password

# =====================================================
# Optional: Advanced Settings
# =====================================================
# Whisper model size (tiny, base, small, medium, large)
WHISPER_MODEL_SIZE=base

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Temperature for LLM responses (0.0 to 1.0)
LLM_TEMPERATURE=0.7

# Maximum tokens for LLM responses
MAX_TOKENS=2000

# =====================================================
# Optional: External Services
# =====================================================
# Google Translate API (fallback for translation)
# GOOGLE_TRANSLATE_API_KEY=your-google-api-key

# =====================================================
# Optional: Tesseract Path (if not in system PATH)
# =====================================================
# Windows example:
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
# Linux/Mac example:
# TESSERACT_CMD=/usr/bin/tesseract

# =====================================================
# Optional: FFmpeg Path (if not in system PATH)
# =====================================================
# Windows example:
# FFMPEG_PATH=C:\\Program Files\\ffmpeg\\bin\\ffmpeg.exe
# Linux/Mac example:
# FFMPEG_PATH=/usr/bin/ffmpeg

# =====================================================
# Security Settings
# =====================================================
# Session secret key for secure sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-random-secret-key-here

# Enable authentication (true/false)
ENABLE_AUTH=false

# =====================================================
# Performance Settings
# =====================================================
# Number of worker threads
WORKER_THREADS=4

# Cache TTL in seconds
CACHE_TTL=3600

# Enable response caching
ENABLE_CACHING=true

# =====================================================
# Deployment Settings
# =====================================================
# Application host
APP_HOST=0.0.0.0

# Application port
APP_PORT=8501

# Enable HTTPS
ENABLE_HTTPS=false

# =====================================================
# Monitoring & Analytics
# =====================================================
# Enable usage tracking
ENABLE_ANALYTICS=false

# Analytics provider (google, mixpanel, custom)
# ANALYTICS_PROVIDER=google
# ANALYTICS_KEY=your-analytics-key

# =====================================================
# Backup Settings
# =====================================================
# Enable automatic backups
ENABLE_AUTO_BACKUP=false

# Backup frequency in hours
BACKUP_FREQUENCY_HOURS=24

# Backup retention days
BACKUP_RETENTION_DAYS=7

# Backup directory
BACKUP_DIR=data/backups

# =====================================================
# Rate Limiting
# =====================================================
# Requests per minute
RATE_LIMIT_PER_MINUTE=60

# Enable rate limiting
ENABLE_RATE_LIMITING=false

# =====================================================
# Email Notifications (Optional)
# =====================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com
# ENABLE_EMAIL_NOTIFICATIONS=false

# =====================================================
# AWS Configuration (Optional, for S3 storage)
# =====================================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# ENABLE_S3_STORAGE=false

# =====================================================
# NOTES
# =====================================================
# 1. After copying this file to .env, update with your actual values
# 2. Keep your .env file secure and never commit it to git
# 3. Restart the application after changing environment variables
# 4. For production, use strong secret keys and enable security features
# 5. Monitor your OpenAI API usage to avoid unexpected costs

# =====================================================
# QUICK START
# =====================================================
# Minimum required configuration:
# 1. Set OPENAI_API_KEY
# 2. (Optional) Adjust LLM_MODEL if needed
# 3. Save as .env
# 4. Run: streamlit run app.py
